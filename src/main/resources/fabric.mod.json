{
  "schemaVersion": 1,
  "id": "ssc_addon",
  "provides": [
    "ssc-addon"
  ],
  "version": "${version}",
  "name": "Shape Shifter Curse Addon",
  "description": "An addon for Shape Shifter Curse mod.",
  "authors": [
    {
      "name": "MangZai-120",
      "contact": {
        "github": "https://github.com/MangZai-120"
      }
    }
  ],
  "contact": {
    "modrinth": "https://modrinth.com/mod/shape-shifter-curse-addon",
    "curseforge": "https://www.curseforge.com/minecraft/mc-mods/shape-shifter-curse-addon",
    "homepage": "https://shape-shifter-curse-addon.readthedocs.io/zh-cn/latest/",
    "sources": "https://github.com/MangZai-120/shape-shifter-curse-addon",
    "issues": "https://github.com/MangZai-120/shape-shifter-curse-addon/issues"
  },
  "license": "AGPL-3.0",
  "icon": "assets/ssc_addon/icon.png",
  "environment": "*",
  "entrypoints": {
    "preLaunch": [
      "net.onixary.shapeShifterCurseFabric.ssc_addon.SscAddonPreLaunch"
    ],
    "main": [
      "net.onixary.shapeShifterCurseFabric.ssc_addon.SscAddon"
    ],
    "client": [
      "net.onixary.shapeShifterCurseFabric.ssc_addon.client.SscAddonClient"
    ],
    "modmenu": [
      "net.onixary.shapeShifterCurseFabric.ssc_addon.compat.ModMenuIntegration"
    ],
    "cardinal-components-entity": [
      "net.onixary.shapeShifterCurseFabric.ssc_addon.evolution.RegEvolutionComponent"
