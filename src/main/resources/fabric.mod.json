  "mixins": [
    "my_addon.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.14.21",
    "minecraft": "1.20.1",
    "java": ">=17",
    "fabric": ">=0.83.0",
    "shape-shifter-curse": ">=1.9.0",
    "trinkets": ">=3.7.2"
  },
  "suggests": {
    "modmenu": "*",
    "lambdynlights": "*",
    "asyncparticles": "*"
  },
  "contributors": [
    {
      "name": "wuhenqiubai",
      "contact": {
        "github": "https://github.com/wuhenqiubai"
      }
    }
  ],
  "custom": {
    "cardinal-components": [
      "ssc_addon:evolution"
    ]
  }
