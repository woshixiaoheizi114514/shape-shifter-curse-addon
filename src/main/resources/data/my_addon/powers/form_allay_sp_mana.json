{
    "type": "apoli:multiple",
    "resource": {
        "type": "apoli:resource",
        "min": 0,
        "max": 100,
        "start_value": 0,
        "hud_render": {
            "should_render": false
        }
    },
    "cooldown_resource": {
        "type": "apoli:resource",
        "min": 0,
        "max": 100,
        "start_value": 0,
        "hud_render": {
            "should_render": false
        }
    },
    "cooldown_tick": {
        "type": "apoli:action_over_time",
        "interval": 1,
        "entity_action": {
            "type": "apoli:change_resource",
            "resource": "my_addon:form_allay_sp_mana_cooldown_resource",
            "change": -1,
            "operation": "add"
        },
        "condition": {
            "type": "apoli:resource",
            "resource": "my_addon:form_allay_sp_mana_cooldown_resource",
            "comparison": ">",
            "compare_to": 0
        }
    },
    "regen": {
        "type": "apoli:action_over_time",
        "interval": 8,
        "entity_action": {
            "type": "apoli:change_resource",
            "resource": "my_addon:form_allay_sp_mana_resource",
            "change": 3,
            "operation": "add"
        },
        "condition": {
            "type": "apoli:and",
            "conditions": [
                {
                    "type": "ssc_addon:skill_disabled",
                    "form": "allay",
                    "skill": "mana_regen"
                },
                {
                    "type": "apoli:resource",
                    "resource": "my_addon:form_allay_sp_mana_resource",
                    "comparison": "<",
                    "compare_to": 100
                },
                {
                    "type": "apoli:resource",
                    "resource": "my_addon:form_allay_sp_mana_cooldown_resource",
                    "comparison": "==",
                    "compare_to": 0
                }
            ]
        }
    },
    "beacon_consume": {
        "type": "apoli:action_over_time",
        "interval": 1,
        "entity_action": {
            "type": "apoli:change_resource",
            "resource": "my_addon:form_allay_sp_mana_resource",
            "change": -1,
            "operation": "add"
        },
        "condition": {
            "type": "apoli:and",
            "conditions": [
                {
                    "type": "apoli:resource",
                    "resource": "my_addon:form_allay_sp_beacon_active",
                    "comparison": "==",
                    "compare_to": 1
                },
                {
                    "type": "apoli:resource",
                    "resource": "my_addon:form_allay_sp_mana_resource",
                    "comparison": ">=",
                    "compare_to": 1
                }
            ]
        }
    },
    "name": "Mana",
    "description": "Custom mana resource for Allay SP form."
}
