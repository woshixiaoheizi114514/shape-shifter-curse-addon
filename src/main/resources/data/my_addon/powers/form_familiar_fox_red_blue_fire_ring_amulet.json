        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 0,
        "hud_render": {
            "should_render": false
        }
    },
    "cooldown_timer": {
        "type": "origins:resource",
        "min": 0,
        "max": 560,
        "start_value": 0,
        "hud_render": {
            "should_render": false,
            "bar_index": 5
        }
    },
    "cooldown_tick": {
        "type": "origins:action_over_time",
        "interval": 1,
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "my_addon:form_familiar_fox_red_blue_fire_ring_amulet_cooldown_timer",
            "operation": "add",
            "change": -1
